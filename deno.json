{
  "tasks": {
    "install": "deno run -A install.ts",
    "dev": "deno run --allow-all --unstable-kv --watch main.ts",
    "build:mac": "deno compile --allow-all --unstable-kv -o bin/codie-mac --target x86_64-apple-darwin main.ts",
    "build:mac-m1": "deno compile --allow-all --unstable-kv -o bin/codie-mac-m1 --target aarch64-apple-darwin main.ts",
    "build:linux": "deno compile --allow-all --unstable-kv -o bin/codie-linux --target x86_64-unknown-linux-gnu main.ts",
    "build:windows": "deno compile --allow-all --unstable-kv -o bin/codie-win.exe --target x86_64-pc-windows-msvc main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "@std/fs": "jsr:@std/fs@1",
    "@cliffy/command": "jsr:@cliffy/command@1.0.0-rc.7",
    "@cliffy/prompt": "jsr:@cliffy/prompt@1.0.0-rc.7",
    "@cliffy/ansi": "jsr:@cliffy/ansi@1.0.0-rc.7",
    "@cliffy/ansi/colors": "jsr:@cliffy/ansi@1.0.0-rc.7/colors",
    "@db/sqlite": "jsr:@db/sqlite@0.11"
  }
}
